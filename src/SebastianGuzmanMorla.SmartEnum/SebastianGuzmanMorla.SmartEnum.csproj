<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
        <PackageId>SebastianGuzmanMorla.SmartEnum</PackageId>
        <Version>1.0.1</Version>
        <Authors>Sebastián Guzmán Morla</Authors>
        <Description>Implementación de SmartEnums con Source Generators.</Description>
        <PackageProjectUrl>https://github.com/sebastianguzmanmorla/SmartEnum</PackageProjectUrl>
        <RepositoryUrl>https://github.com/sebastianguzmanmorla/SmartEnum.git</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageLicenseFile>LICENSE</PackageLicenseFile>
        <PackageTags>smart-enum;source-generator;enum;csharp;dotnet;entity-framework;json</PackageTags>
        <Copyright>© 2026 Sebastián Guzmán Morla</Copyright>
    </PropertyGroup>

    <ItemGroup>
        <None Include="..\..\README.md" Pack="true" PackagePath="\"/>
        <None Include="..\..\LICENSE" Pack="true" PackagePath="\"/>
    </ItemGroup>

    <Target Name="PrintVersion">
        <Error Text="$(Version)"/>
    </Target>

    <ItemGroup>
        <PackageReference Include="Microsoft.EntityFrameworkCore" Version="10.0.6" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\SebastianGuzmanMorla.SmartEnum.Generator\SebastianGuzmanMorla.SmartEnum.Generator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    </ItemGroup>

    <ItemGroup>
        <None Include="..\SebastianGuzmanMorla.SmartEnum.Generator\bin\$(Configuration)\netstandard2.0\SebastianGuzmanMorla.SmartEnum.Generator.dll" 
              Pack="true" 
              PackagePath="analyzers/dotnet/cs" />
    </ItemGroup>

</Project>
