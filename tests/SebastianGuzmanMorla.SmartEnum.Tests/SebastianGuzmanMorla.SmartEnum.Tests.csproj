<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <IsPackable>false</IsPackable>
        <IsTestProject>true</IsTestProject>
    </PropertyGroup>

    <!-- Import the source generator from the main library -->
    <ItemGroup>
        <ProjectReference Include="..\SebastianGuzmanMorla.SmartEnum.Tests.Types\SebastianGuzmanMorla.SmartEnum.Tests.Types.csproj" />
